page {
  min-height: 100%;
  color: #f4f0d8;
  background: #0f1218;
  font-family: "Courier New", monospace;
  image-rendering: pixelated;
}

view,
text,
button {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1;
  border-radius: 0;
}

button::after {
  border: 0;
}

.screen {
  min-height: 100vh;
  padding: 24rpx;
  background:
    linear-gradient(180deg, rgba(29, 38, 54, 0.92), rgba(15, 18, 24, 1)),
    repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.04) 0 2rpx, transparent 2rpx 24rpx);
}

.pixel-panel {
  border: 6rpx solid #f4f0d8;
  background: #1b2130;
  box-shadow: 8rpx 8rpx 0 #05070b;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f8d84a;
}

.subtle {
  color: #aeb6c8;
  font-size: 24rpx;
}

.pixel-button {
  height: 88rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111318;
  background: #f8d84a;
  border: 6rpx solid #fff2a4;
  box-shadow: 0 8rpx 0 #9f7722;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.pixel-button[disabled] {
  color: #737b8a;
  background: #343b4a;
  border-color: #596070;
  box-shadow: none;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 8rpx 14rpx;
  color: #f4f0d8;
  background: #272e3e;
  border: 4rpx solid #525b6d;
  font-size: 22rpx;
}

.progress {
  width: 100%;
  height: 34rpx;
  padding: 4rpx;
  background: #0a0d12;
  border: 4rpx solid #f4f0d8;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #f0523f, #f8d84a, #37d67a);
}
