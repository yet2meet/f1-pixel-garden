<view class="screen">
  <view class="header">
    <text class="panel-title">本周好友榜</text>
    <text class="subtle">周日 23:59 结算，榜首获得本周冠军。</text>
  </view>

  <view class="rank-list">
    <view wx:for="{{rankings}}" wx:key="id" class="rank-card pixel-panel {{item.mine ? 'mine' : ''}}">
      <text class="place">#{{index + 1}}</text>
      <view class="mini-helmet" style="background: {{item.driver.palette[0]}}; border-color: {{item.driver.palette[2]}};">
        <view style="background: {{item.driver.palette[1]}};"></view>
        <text>{{item.driver.badge}}</text>
      </view>
      <view class="meta">
        <text class="name">{{item.nickName}}</text>
        <text class="subtle">{{item.driver.name}}</text>
      </view>
      <view class="score">
        <text>{{item.feed}}</text>
        <text class="subtle">喂食量</text>
      </view>
    </view>
  </view>

  <button class="pixel-button share" open-type="share">分享战绩卡</button>
</view>
