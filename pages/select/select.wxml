<view class="screen select-screen">
  <view class="hero">
    <text class="panel-title">绑定你的 F1 车手</text>
    <text class="subtle">可以随时更换车手；更换后喂食与成长会重新计算。</text>
  </view>

  <view class="driver-grid">
    <view
      wx:for="{{drivers}}"
      wx:key="id"
      class="driver-card pixel-panel {{selectedId === item.id ? 'active' : ''}} {{currentDriverId === item.id ? 'current' : ''}}"
      bindtap="chooseDriver"
      data-id="{{item.id}}"
    >
      <view class="driver-portrait" style="border-color: {{item.palette[2]}};">
        <image class="portrait-frame" src="{{item.portrait}}" mode="scaleToFill"></image>
        <view class="mini-helmet" style="background: {{item.palette[0]}}; border-color: {{item.palette[2]}};">
          <view style="background: {{item.palette[1]}};"></view>
          <text>{{item.badge}}</text>
        </view>
      </view>
      <view class="driver-info">
        <text class="driver-name">{{item.name}}</text>
        <text class="subtle">{{item.team}}</text>
      </view>
      <text class="food">#{{item.number}} {{item.moodEmoji}} {{item.foodEmoji}} {{item.food}}</text>
    </view>
  </view>

  <button class="pixel-button confirm" disabled="{{!selectedId}}" bindtap="confirmDriver">确认绑定</button>
</view>
