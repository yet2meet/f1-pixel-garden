.header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.gallery {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.driver-card {
  padding: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.driver-card.selected {
  border-color: #f8d84a;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.mini-helmet {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  border: 6rpx solid;
  box-shadow: 5rpx 5rpx 0 #05070b;
}

.mini-helmet view {
  width: 46rpx;
  height: 18rpx;
  margin: 19rpx 0 0 14rpx;
}

.mini-helmet text {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 8rpx;
  color: #f4f0d8;
  font-size: 20rpx;
  font-weight: 700;
  text-align: center;
}

.name {
  color: #f4f0d8;
  font-size: 32rpx;
  font-weight: 700;
}

.food {
  color: #f8d84a;
  font-size: 26rpx;
}

.story {
  color: #cfd6dd;
  font-size: 24rpx;
  line-height: 38rpx;
}

.skins {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.skins text {
  padding: 12rpx 0;
  text-align: center;
  color: #aeb6c8;
  background: #111722;
  border: 4rpx solid #3b4354;
  font-size: 22rpx;
}
