<view class="screen">
  <view class="summary pixel-panel">
    <text class="panel-title">成长档案</text>
    <text class="subtle">{{player ? '本周继续冲榜，成长值每周累积不清零。' : '绑定车手后开始记录成长。'}}</text>
    <view class="growth-row">
      <view>
        <text class="value">{{player ? player.growth : 0}}</text>
        <text class="subtle">成长值</text>
      </view>
      <view>
        <text class="value">{{levelName}}</text>
        <text class="subtle">当前等级</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="panel-title">等级路线</text>
    <view class="level-list">
      <view wx:for="{{levels}}" wx:key="name" class="level-item {{growth >= item.minGrowth ? 'done' : ''}}">
        <text>{{item.name}}</text>
        <text>{{item.minGrowth}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="panel-title">历史周冠军</text>
    <view class="empty-history">
      <text>等待第一次周日结算</text>
    </view>
  </view>
</view>
