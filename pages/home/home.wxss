.home-screen {
  padding-bottom: 40rpx;
}

.empty {
  margin-top: 160rpx;
  padding: 34rpx;
  display: flex;
  flex-direction: column;
  gap: 26rpx;
}

.topbar {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.topbar > view {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stage {
  position: relative;
  height: 520rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, #263954 0 46%, #30363a 46% 100%),
    repeating-linear-gradient(90deg, transparent 0 34rpx, rgba(255,255,255,0.08) 34rpx 38rpx);
}

.stage::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: repeating-linear-gradient(0deg, transparent 0 30rpx, rgba(255,255,255,0.05) 30rpx 32rpx);
  pointer-events: none;
  z-index: 0;
}

.lucky-stage {
  animation: luckyPulse 640ms steps(2, end);
}

.speech {
  position: relative;
  width: 100%;
  min-height: 64rpx;
  margin-top: 18rpx;
  padding: 12rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #f4f0d8;
  background: rgba(5, 7, 11, 0.92);
  border: 4rpx solid #f8d84a;
  box-shadow: 6rpx 6rpx 0 rgba(0, 0, 0, 0.32);
  font-size: 24rpx;
  font-weight: 700;
  z-index: 1;
}

.speech::after {
  display: none;
}

.speech-emoji {
  font-size: 34rpx;
}

.driver-sprite {
  position: absolute;
  left: 50%;
  top: 26rpx;
  width: 384rpx;
  height: 480rpx;
  overflow: hidden;
  transform: translateX(-50%);
  z-index: 1;
}

.driver-frame {
  width: 384rpx;
  height: 480rpx;
  display: block;
  image-rendering: pixelated;
}

.food-flyer {
  position: absolute;
  right: 70rpx;
  bottom: 28rpx;
  font-size: 58rpx;
  z-index: 4;
  animation: foodFly 720ms steps(6, end) forwards;
  pointer-events: none;
}

.feed-delta {
  position: absolute;
  left: 50%;
  top: 276rpx;
  min-width: 92rpx;
  padding: 8rpx 12rpx;
  color: #111318;
  background: #37d67a;
  border: 4rpx solid #f4f0d8;
  box-shadow: 5rpx 5rpx 0 #05070b;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  transform: translateX(-50%);
  z-index: 4;
  animation: deltaPop 920ms steps(5, end) forwards;
  pointer-events: none;
}

.lucky-delta {
  background: #f8d84a;
  color: #111318;
}

.lucky-banner {
  position: absolute;
  left: 50%;
  top: 78rpx;
  padding: 8rpx 18rpx;
  color: #111318;
  background: #f8d84a;
  border: 4rpx solid #ffffff;
  box-shadow: 5rpx 5rpx 0 #05070b;
  font-size: 28rpx;
  font-weight: 700;
  transform: translateX(-50%);
  z-index: 4;
  animation: luckyBanner 780ms steps(4, end) forwards;
  pointer-events: none;
}

.driver-watermark {
  position: absolute;
  right: 28rpx;
  bottom: 60rpx;
  color: rgba(244, 240, 216, 0.08);
  font-size: 112rpx;
  font-weight: 700;
  line-height: 1;
  z-index: 0;
  pointer-events: none;
}

.driver-corner {
  position: absolute;
  left: 24rpx;
  top: 22rpx;
  bottom: auto;
  min-width: 132rpx;
  padding: 10rpx 12rpx;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  color: #f4f0d8;
  background: rgba(17, 19, 24, 0.82);
  border: 4rpx solid #f8d84a;
  z-index: 1;
  pointer-events: none;
}

.driver-corner text:first-child {
  color: #f8d84a;
  font-size: 28rpx;
  font-weight: 700;
}

.driver-corner text:last-child {
  font-size: 20rpx;
}

.track-line {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 72rpx;
  height: 10rpx;
  background: repeating-linear-gradient(90deg, #f4f0d8 0 42rpx, transparent 42rpx 84rpx);
  z-index: 0;
  pointer-events: none;
}

.status {
  margin-top: 26rpx;
  padding: 22rpx;
}

.row,
.log-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.row {
  margin-bottom: 14rpx;
  font-size: 28rpx;
}

.mission-strip {
  min-height: 54rpx;
  margin-top: 16rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #f4f0d8;
  background: #111722;
  border: 4rpx solid #3b4354;
  font-size: 24rpx;
}

.mission-strip text:last-child {
  color: #f8d84a;
  font-weight: 700;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 14rpx;
}

.stats view {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 14rpx 10rpx;
  background: #111722;
  border: 4rpx solid #3b4354;
}

.stat-value {
  color: #f8d84a;
  font-size: 34rpx;
  font-weight: 700;
}

.feed-button {
  width: 100%;
  margin-top: 28rpx;
  transition: transform 80ms steps(1, end), box-shadow 80ms steps(1, end);
}

.feed-button-press,
.feed-button.feeding {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #9f7722;
}

.ghost-button {
  width: 100%;
  height: 72rpx;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f4f0d8;
  background: #202838;
  border: 4rpx solid #596070;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.logs {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
  max-height: 172rpx;
  overflow: hidden;
}

.log-item {
  padding: 16rpx 20rpx;
  color: #cfd6dd;
  background: #151b26;
  border-left: 8rpx solid #f8d84a;
  font-size: 24rpx;
}

@keyframes foodFly {
  0% {
    transform: translate(0, 0) scale(1);
    opacity: 1;
  }
  30% {
    transform: translate(-70rpx, -120rpx) scale(1.12);
  }
  70% {
    transform: translate(-188rpx, -198rpx) scale(0.92);
    opacity: 1;
  }
  100% {
    transform: translate(-226rpx, -220rpx) scale(0.2);
    opacity: 0;
  }
}

@keyframes deltaPop {
  0% {
    transform: translate(-50%, 20rpx) scale(0.7);
    opacity: 0;
  }
  20% {
    transform: translate(-50%, 0) scale(1.08);
    opacity: 1;
  }
  72% {
    transform: translate(-50%, -36rpx) scale(1);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -58rpx) scale(0.86);
    opacity: 0;
  }
}

@keyframes luckyPulse {
  0% {
    box-shadow: 8rpx 8rpx 0 #05070b, inset 0 0 0 rgba(248, 216, 74, 0);
  }
  35% {
    box-shadow: 8rpx 8rpx 0 #05070b, inset 0 0 0 999rpx rgba(248, 216, 74, 0.18);
  }
  100% {
    box-shadow: 8rpx 8rpx 0 #05070b, inset 0 0 0 rgba(248, 216, 74, 0);
  }
}

@keyframes luckyBanner {
  0% {
    transform: translateX(-50%) scale(0.72);
    opacity: 0;
  }
  24% {
    transform: translateX(-50%) scale(1.08);
    opacity: 1;
  }
  74% {
    transform: translateX(-50%) scale(1);
    opacity: 1;
  }
  100% {
    transform: translateX(-50%) scale(0.92);
    opacity: 0;
  }
}
