<view class="screen home-screen">
  <block wx:if="{{!hasPlayer}}">
    <view class="empty pixel-panel">
      <text class="panel-title">欢迎来到维修区</text>
      <text class="subtle">先绑定一位车手，今天就可以开始投喂专属食物并冲击本周冠军。</text>
      <button class="pixel-button" bindtap="goSelect">选择车手</button>
    </view>
  </block>

  <block wx:if="{{hasPlayer}}">
    <view class="topbar">
      <view>
        <text class="panel-title">{{driver.name}}</text>
        <text class="subtle">#{{driver.number}} · {{driver.team}} · {{level.name}}</text>
      </view>
      <text class="tag">{{driver.foodEmoji}} {{driver.food}}</text>
    </view>

    <view class="stage pixel-panel {{luckyFlash ? 'lucky-stage' : ''}}" bindtap="talkToDriver">
      <view class="driver-watermark">#{{driver.number}}</view>
      <view class="driver-corner" style="border-color: {{driver.palette[2]}};">
        <text>{{driver.badge}}</text>
        <text>{{driver.team}}</text>
      </view>
      <view class="driver-sprite" bindtap="talkToDriver">
        <image class="driver-frame" src="{{spriteFrameSrc}}" mode="scaleToFill"></image>
      </view>
      <view wx:if="{{floatingFood}}" class="food-flyer">{{driver.foodEmoji}}</view>
      <view wx:if="{{feedDelta}}" class="feed-delta {{luckyFlash ? 'lucky-delta' : ''}}">+{{feedDelta}}</view>
      <view wx:if="{{luckyFlash}}" class="lucky-banner">LUCKY x2</view>
      <view class="track-line"></view>
    </view>

    <view wx:if="{{driverLine}}" class="speech">
      <text class="speech-emoji">{{driver.moodEmoji}}</text>
      <text>{{driverLine}}</text>
    </view>

    <view class="status pixel-panel">
      <view class="row">
        <text>本周喂食量</text>
        <text>{{state.weeklyFeed}}</text>
      </view>
      <view class="progress">
        <view class="progress-fill" style="width: {{progress}}%;"></view>
      </view>
      <view class="mission-strip">
        <text>今日任务</text>
        <text>{{state.usedFeeds || 0}} / 5</text>
      </view>
      <view class="stats">
        <view>
          <text class="stat-value">{{remainFeeds}}</text>
          <text class="subtle">剩余次数</text>
        </view>
        <view>
          <text class="stat-value">{{state.stock}}</text>
          <text class="subtle">食物库存</text>
        </view>
        <view>
          <text class="stat-value">{{player.growth}}</text>
          <text class="subtle">成长值</text>
        </view>
      </view>
    </view>

    <button class="pixel-button feed-button {{isFeeding ? 'feeding' : ''}}" hover-class="feed-button-press" disabled="{{remainFeeds <= 0 || state.stock <= 0 || isFeeding}}" bindtap="feed">
      投喂 {{driver.food}}
    </button>

    <button class="ghost-button" bindtap="goSelect">更换车手</button>

    <view class="logs">
      <view wx:for="{{state.logs}}" wx:key="id" class="log-item">
        <text>{{item.lucky ? '幸运双倍' : '进站补给'}}</text>
        <text>+{{item.value}}</text>
      </view>
    </view>
  </block>
</view>
